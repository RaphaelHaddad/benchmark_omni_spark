# Image and container names
VLLM_IMAGE=qwen3-omni-vllm:latest
CONTAINER_NAME=qwen3-omni-vllm

# Model configuration
MODEL_PATH=/home/hci-ai/Documents/models/models/Qwen3-Omni-30B-A3B-Instruct
SERVED_MODEL_NAME=qwen3-omni
VLLM_HOST=0.0.0.0
VLLM_PORT=8078
VLLM_API_KEY=qwen3-omni-api-key

# Cache and logs
HF_CACHE_DIR=${HOME}/.cache/huggingface
VLLM_CACHE_DIR=${HOME}/.cache/vllm
LOG_DIR=/tmp/vlm_logs
VIDEO_DIR=./videos

# Performance tuning
GPU_MEMORY_UTILIZATION=0.85
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=32768

# GPU settings
NVIDIA_VISIBLE_DEVICES=all
